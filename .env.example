# ---------- Backend ----------
# OpenAI API anahtarı (zorunlu — agent'lar bunu kullanır)
OPENAI_API_KEY=key_here

# Görsel modeli
OPENAI_MODEL=gpt-image-1

# Kullanılacak model (varsayılan: gpt-4o-mini; gpt-4o da kullanılabilir)
OPENAI_MODEL=gpt-4o-mini

# JWT imzalama anahtarı — production'da uzun ve rastgele bir değer kullanın
# (örn. `openssl rand -hex 32` çıktısı)
JWT_SECRET=secure_random_value_here

# Token geçerlilik süresi (dakika)
JWT_EXPIRE_MINUTES=1440

# Veritabanı bağlantısı.
# Lokal geliştirme: boş bırakın (SQLite'a düşer: sqlite:///./orkestrai.db)
# Railway production: PostgreSQL eklentisinin verdiği DATABASE_URL otomatik gelir
DATABASE_URL=

# İzin verilen frontend origin'leri (virgülle ayrılmış)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Frontend (frontend/.env dosyasına) ----------
# Backend API adresi (lokalde http://localhost:8000, production'da Railway backend URL'i)
VITE_API_URL=http://localhost:8000
